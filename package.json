{
  "name": "llm-proxy",
  "version": "1.0.0",
  "description": "A neutral, lightweight LLM proxy for token statistics and cost audit.",
  "type": "module",
  "bin": {
    "llm-proxy": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --no-warnings --import tsx/esm src/index.ts",
    "start": "node --no-warnings --import tsx/esm src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.19.0",
    "tsx": "^4.7.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
